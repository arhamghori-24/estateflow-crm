# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgres://postgres:password@db.YOUR-PROJECT.supabase.co:5432/postgres

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# --- Dry-run mode (no external API calls) ---
# When true, callService/messageService/emailService log to DB + console only.
SERVICES_DRY_RUN=true

# --- Twilio Voice / SMS / WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Resend (email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=EstateFlow <noreply@estateflow.app>

# --- OpenAI (optional, for AI message/post drafting) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Webhook security ---
LEAD_WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- Cron secret (for Vercel Cron / external scheduler hitting /api/cron/*) ---
CRON_SECRET=change-me-to-a-long-random-string

# --- Rate limiting (optional) ---
# If unset, rate limiting on /api/webhooks/leads is skipped (fail-open).
# Create a free database at https://upstash.com to enable.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
